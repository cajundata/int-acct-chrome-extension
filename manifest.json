{
  "manifest_version": 3,
  "name": "Question Extractor",
  "version": "1.7.0",
  "description": "Extracts questions from web pages to assist with school work",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ]
}
